/* Switch between Invitation / RSVP / Responses tabs */
function showPage(p) {
  document.querySelectorAll('.page').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(el => el.classList.remove('active'));

  const page = document.getElementById('page-' + p);
  if (page) page.classList.add('active');

  const tabOrder = ['invite', 'rsvp', 'responses'];
  const tabIdx   = tabOrder.indexOf(p);
  const tabs     = document.querySelectorAll('.tab');
  if (tabs[tabIdx]) tabs[tabIdx].classList.add('active');

  // Re-render table when switching to responses
  if (p === 'responses') renderResponses();
}

/* Toggle collapsible info block (Dress Code / Program) */
function toggleInfo(header) {
  header.classList.toggle('open');
  const body = header.nextElementSibling;
  if (body) body.classList.toggle('open');
}

/* Helper to show/hide the Responses tab and page */
function setResponsesVisibility(visible) {
  const tab = document.getElementById('tab-responses');
  const page = document.getElementById('page-responses');
  if (tab) tab.style.display = visible ? '' : 'none';
  if (page) page.style.display = visible ? '' : 'none';
}

/* Invite modal controls */
function showInviteModal(nickname, role) {
  const modal = document.getElementById('invite-modal');
  const body = document.getElementById('invite-modal-body');
  if (!modal || !body) return;
  const friendly = role === 'entourage' ? 'Entourage' : role === 'sponsor' ? 'Sponsor' : 'Guest';
  body.textContent = `We want to invite you as "${nickname}" (${friendly}).`;
  modal.classList.add('open');
  modal.setAttribute('aria-hidden', 'false');
}

function closeInviteModal() {
  const modal = document.getElementById('invite-modal');
  if (!modal) return;
  modal.classList.remove('open');
  modal.setAttribute('aria-hidden', 'true');
}

/* Apply invite type to RSVP form (preselect) */
function applyInviteType(role) {
  const typeEl = document.getElementById('rsvp-type');
  if (!typeEl) return;
  if (['guest', 'entourage', 'sponsor'].includes(role)) {
    typeEl.value = role;
    // toggleSponsor is defined in js/rsvp.js
    if (typeof toggleSponsor === 'function') toggleSponsor();
    // Update visible role display if present
    const disp = document.getElementById('rsvp-role-display');
    if (disp) {
      const friendly = role === 'entourage' ? 'Entourage' : role === 'sponsor' ? 'Sponsor' : 'Guest';
      disp.textContent = friendly;
    }
  }
}

/* Show an invite banner and filter dress cards for the role.
   Behaviour:
   - If role === 'guest' hide entourage cards
   - If role === 'entourage' hide guest cards
   - Otherwise show all cards
*/
function showInviteBanner(role, person, nickname) {
  const banner = document.getElementById('invite-banner');
  if (!banner) return;
  if (!role) { banner.style.display = 'none'; return; }
  const friendly = role === 'entourage' ? 'Entourage' : role === 'sponsor' ? 'Sponsor' : 'Guest';
  if (person && nickname) {
    banner.textContent = `${person} — We want to invite you as "${nickname}" (${friendly}).`;
  } else if (person) {
    banner.textContent = `${person} — Invitation role: ${friendly}`;
  } else if (nickname) {
    banner.textContent = `We want to invite you as "${nickname}" (${friendly}).`;
  } else {
    banner.textContent = `This invitation is for: ${friendly}.`;
  }
  banner.style.display = 'block';

  // Show/hide dress cards depending on role
  document.querySelectorAll('.dress-card').forEach(card => {
    const r = (card.getAttribute('data-role') || 'guest').toLowerCase();
    if (role === 'guest') {
      // hide entourage cards
      card.style.display = r === 'entourage' ? 'none' : '';
    } else if (role === 'entourage') {
      // hide guest cards
      card.style.display = r === 'guest' ? 'none' : '';
    } else {
      // sponsor or unknown: show all
      card.style.display = '';
    }
  });
}

/* Parse URL params and initialise invite/admin behaviour */
document.addEventListener('DOMContentLoaded', () => {
  // Load saved responses on start (renders only if Responses tab visible)
  renderResponses();

  const params = new URLSearchParams(window.location.search);
  const token = params.get('token');
  let invite = (params.get('invite') || '').toLowerCase();
  const admin  = params.get('admin');
  let inviteName = null;

  // If token param present, prefer token lookup from INVITE_TOKENS
  if (token && typeof getInviteByToken === 'function') {
    const rec = getInviteByToken(token);
    if (rec && rec.role) {
      invite = rec.role.toLowerCase();
      inviteName = rec.name || null;
      // accept nickname field if present
      var inviteNick = rec.nickname || rec.nick || null;
      // expose inviteNick to outer scope by attaching to window for later use
      window.__inviteNick = inviteNick;
    }
  }

  // If invite param or token-derived invite set, apply it
  if (invite) {
    applyInviteType(invite);
    // pass nickname from token mapping if available
    showInviteBanner(invite, inviteName, window.__inviteNick || null);

    // If invite name provided via token, pre-fill the name input value instead of using placeholder
    const nameInput = document.getElementById('rsvp-name');
    if (nameInput) {
      if (inviteName) {
        nameInput.value = inviteName;
      } else {
        nameInput.placeholder = nameInput.placeholder || 'Your full name';
      }
    }

    // If nickname is present in token, show modal
    if (window.__inviteNick) {
      showInviteModal(window.__inviteNick, invite);
    }
  }

  // Show Responses tab only if admin param present (owner link)
  // Keep this simple: anyone with the admin link can view Responses.
  const isAdmin = !!admin;
  setResponsesVisibility(isAdmin);

  // If admin present, and Responses are visible, show responses tab by default
  if (isAdmin) {
    // Ensure the Responses tab is selectable and render table
    renderResponses();
  } else {
    // If not admin and currently on responses page (e.g., direct link), redirect to invite
    if (window.location.hash.includes('responses') || (document.getElementById('page-responses') && document.getElementById('page-responses').classList.contains('active'))) {
      showPage('invite');
    }
  }
});
