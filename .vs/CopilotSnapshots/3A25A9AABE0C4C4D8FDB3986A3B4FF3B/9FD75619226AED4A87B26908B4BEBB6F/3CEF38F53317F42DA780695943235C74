<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Myrrah Ericka & Neil Brandon — Wedding Invitation</title>

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:wght@300;400&display=swap" rel="stylesheet">

  <!-- Stylesheets -->
  <link rel="stylesheet" href="css/base.css">
  <link rel="stylesheet" href="css/components.css">
  <link rel="stylesheet" href="css/pages.css">
  <style>
    /* small inline style for invite banner; move to CSS if desired */
    .invite-banner {
      display: none;
      background: var(--accent-bg, #f6f3ee);
      color: var(--text-primary, #222);
      padding: 0.6rem 1rem;
      border-radius: 6px;
      margin: 1rem 0;
      font-weight: 500;
      text-align: center;
    }
    /* Invite modal */
    .invite-modal {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.45);
      align-items: center;
      justify-content: center;
      z-index: 1000;
    }
    .invite-modal.open { display: flex; }
    .invite-modal .modal-card {
      background: #fff;
      padding: 20px 18px;
      border-radius: 10px;
      max-width: 420px;
      width: 90%;
      box-shadow: 0 10px 30px rgba(0,0,0,0.2);
      text-align: center;
    }
    .invite-modal .modal-title { font-size:18px;margin-bottom:8px;font-weight:600 }
    .invite-modal .modal-body { font-size:15px;color:var(--text-secondary,#555);margin-bottom:14px }
    .invite-modal .modal-actions { display:flex;gap:8px;justify-content:center }
    .invite-modal .btn { padding:8px 12px;border-radius:6px;border:0;cursor:pointer }
    .invite-modal .btn.primary { background:var(--accent, #7a5cfc);color:#fff }
    .invite-modal .btn.ghost { background:transparent;border:1px solid #ddd }
    .invite-banner .invite-greet { font-size:16px; font-weight:600; margin-bottom:4px }
    .invite-banner .invite-as { font-size:14px; color:var(--text-secondary,#555) }
  </style>
</head>
<body>

<!-- Hidden file input for photo upload -->
<input type="file" id="photo-input" accept="image/*">

<div class="wrap">

  <!-- ═══ TAB BAR ═══ -->
  <div class="tab-bar">
    <button class="tab active" onclick="showPage('invite')">Invitation</button>
    <button class="tab" onclick="showPage('rsvp')">RSVP</button>
    <button class="tab" onclick="showPage('responses')" id="tab-responses">Responses</button>
  </div>

  <!-- Invite-specific banner (shown when ?invite=guest|entourage|sponsor) -->
  <div id="invite-banner" class="invite-banner"></div>

  <!-- ═══════════════════════════════════
       PAGE 1 — INVITATION
  ═══════════════════════════════════ -->
  <div id="page-invite" class="page active">

    <div class="hero">

      <!-- COUPLE PHOTO
           ── EDIT: Click the circle in the browser to upload a photo, OR
              replace images/couple/photo.jpg with your actual photo file
              and change the src below to "images/couple/photo.jpg"        -->
      <div class="photo-frame" onclick="document.getElementById('photo-input').click()" title="Tap to upload couple photo">
        <img id="couple-photo" src="" alt="Couple photo">
        <div class="photo-placeholder" id="photo-placeholder">
          <img src="images/icons/camera.svg" alt="Upload photo" class="placeholder-icon">
          <span>Add photo</span>
        </div>
      </div>

      <!-- ── EDIT: Change date ── -->
      <div class="hero-date">September 24, 2027</div>
      <div class="hero-label">the wedding of</div>

      <!-- ── EDIT: Change bride & groom names ── -->
      <div class="hero-names">Myrrah Ericka Llanera</div>
      <span class="hero-amp">&amp;</span>
      <div class="hero-names">Neil Brandon Salvador</div>

      <div class="hero-divider"></div>

      <!-- ── EDIT: Change venue & time ── -->
      <div class="hero-venue">
        Bella Rosa Gardens · Silang, Cavite<br>
        4:00 PM · Ceremony &amp; Reception
      </div>
    </div>

    <!-- COUNTDOWN TIMER
         ── EDIT: Update WEDDING_DATE in js/countdown.js ── -->
    <div class="countdown-wrap">
      <div class="countdown-unit">
        <span class="countdown-num" id="cd-days">--</span>
        <span class="countdown-lbl">Days</span>
      </div>
      <div class="countdown-unit">
        <span class="countdown-num" id="cd-hours">--</span>
        <span class="countdown-lbl">Hours</span>
      </div>
      <div class="countdown-unit">
        <span class="countdown-num" id="cd-mins">--</span>
        <span class="countdown-lbl">Minutes</span>
      </div>
      <div class="countdown-unit">
        <span class="countdown-num" id="cd-secs">--</span>
        <span class="countdown-lbl">Seconds</span>
      </div>
    </div>

    <!-- NAVIGATION BUTTONS
         ── EDIT: Update venue name in the href URLs in js/navigation.js ── -->
    <div class="nav-row">
      <a class="nav-btn" id="google-maps-btn" href="#" target="_blank">
        <img src="images/icons/map-pin.svg" alt="" class="btn-icon">
        Google Maps
      </a>
      <a class="nav-btn" id="waze-btn" href="#" target="_blank">
        <img src="images/icons/waze.svg" alt="" class="btn-icon">
        Waze
      </a>
    </div>

    <!-- DRESS CODE -->
    <div class="info-block">
      <div class="info-header open" onclick="toggleInfo(this)">
        <span>Dress Code</span>
        <img src="images/icons/chevron.svg" alt="" class="chevron-icon">
      </div>
      <div class="info-body open">
        <!-- ── EDIT: Update swatch color (hex), role, description, note ── -->
        <div class="dress-grid">
          <div class="dress-card" data-role="guest">
            <div class="dress-swatch" style="background:#F5F0EB;"></div>
            <div class="dress-role">Guests — Ladies</div>
            <div class="dress-desc">Cocktail / Formal</div>
            <div class="dress-note">Warm neutrals, blush, ivory, champagne</div>
          </div>
          <div class="dress-card" data-role="guest">
            <div class="dress-swatch" style="background:#C8D4CC;"></div>
            <div class="dress-role">Guests — Gentlemen</div>
            <div class="dress-desc">Barong or Suit</div>
            <div class="dress-note">Sage green, slate, or classic black</div>
          </div>
          <div class="dress-card" data-role="entourage">
            <div class="dress-swatch" style="background:#D4C5B8;"></div>
            <div class="dress-role">Entourage — Ladies</div>
            <div class="dress-desc">Dusty Rose Gown</div>
            <div class="dress-note">Floor-length, as coordinated</div>
          </div>
          <div class="dress-card" data-role="entourage">
            <div class="dress-swatch" style="background:#3D3D3D;"></div>
            <div class="dress-role">Entourage — Gentlemen</div>
            <div class="dress-desc">Black Barong</div>
            <div class="dress-note">As provided by the couple</div>
          </div>
        </div>
        <!-- ── EDIT: Update the dress note ── -->
        <div class="dress-notice">
          <div class="dress-notice-label">Please note</div>
          <p>Kindly avoid wearing white, off-white, or any shade reserved for the bride. Thank you for helping make our day special.</p>
        </div>
      </div>
    </div>

    <!-- PROGRAM OF EVENTS -->
    <div class="info-block">
      <div class="info-header" onclick="toggleInfo(this)">
        <span>Program of Events</span>
        <img src="images/icons/chevron.svg" alt="" class="chevron-icon">
      </div>
      <div class="info-body">
        <!-- ── EDIT: Add / remove .program-item blocks ── -->
        <div class="program-item">
          <div class="prog-time">3:00 PM</div>
          <div><div class="prog-event">Guest Arrival &amp; Registration</div><div class="prog-sub">Welcome drinks at the garden foyer</div></div>
        </div>
        <div class="program-item">
          <div class="prog-time">4:00 PM</div>
          <div><div class="prog-event">Wedding Ceremony</div><div class="prog-sub">Processional · Rites · Exchange of vows</div></div>
        </div>
        <div class="program-item">
          <div class="prog-time">5:00 PM</div>
          <div><div class="prog-event">Cocktail Hour</div><div class="prog-sub">Garden terrace · Photo opportunities</div></div>
        </div>
        <div class="program-item">
          <div class="prog-time">6:00 PM</div>
          <div><div class="prog-event">Reception &amp; Dinner</div><div class="prog-sub">Entrance of newlyweds · Program proper</div></div>
        </div>
        <div class="program-item">
          <div class="prog-time">6:30 PM</div>
          <div><div class="prog-event">Toasts &amp; Messages</div><div class="prog-sub">Principal sponsors · Best man · Maid of honor</div></div>
        </div>
        <div class="program-item">
          <div class="prog-time">7:00 PM</div>
          <div><div class="prog-event">First Dance &amp; Special Dances</div><div class="prog-sub">Couple · Parents · Money dance</div></div>
        </div>
        <div class="program-item">
          <div class="prog-time">8:00 PM</div>
          <div><div class="prog-event">Open Dance Floor</div><div class="prog-sub">Live entertainment · Dessert buffet</div></div>
        </div>
        <div class="program-item">
          <div class="prog-time">10:00 PM</div>
          <div><div class="prog-event">Bouquet Toss &amp; Send-off</div><div class="prog-sub">Thank you &amp; farewell</div></div>
        </div>
      </div>
    </div>

    <!-- RSVP CTA -->
    <!-- ── EDIT: Update RSVP deadline text ── -->
    <div class="rsvp-cta">
      <div class="rsvp-cta-label">Kindly confirm by August 1, 2027</div>
      <div class="rsvp-cta-sub">We hope to celebrate with you</div>
      <button class="submit-btn" onclick="showPage('rsvp')">Send My RSVP</button>
    </div>

  </div><!-- /page-invite -->


  <!-- ═══════════════════════════════════
       PAGE 2 — RSVP FORM
  ═══════════════════════════════════ -->
  <div id="page-rsvp" class="page">

    <div id="rsvp-form-wrap" class="section">
      <div class="section-label" style="margin-bottom:1.5rem;">Your response</div>
      <div class="rsvp-card">
        <label>Full name</label>
        <input type="text" id="rsvp-name" placeholder="Your full name">

        <label>Invitation role</label>
        <!-- Role is set automatically from the invite link. Hidden input keeps existing logic. -->
        <input type="hidden" id="rsvp-type" value="guest">
        <div id="rsvp-role-display" style="margin:0.5rem 0;color:var(--text-primary);font-weight:500;">Guest</div>

        <label>Will you attend?</label>
        <div class="attend-row">
          <button class="attend-btn" id="btn-yes" onclick="selectAttend('yes')">Joyfully accepts</button>
          <button class="attend-btn" id="btn-no"  onclick="selectAttend('no')">Regretfully declines</button>
        </div>

        <label>Message to the couple <span class="optional-tag">(optional)</span></label>
        <textarea id="rsvp-msg" placeholder="Share your wishes..."></textarea>

        <!-- Sponsor-only fields -->
        <div id="sponsor-fields" style="display:none;">
          <label>Company / Organization</label>
          <input type="text" id="rsvp-company" placeholder="Company name">
          <label>Sponsorship type</label>
          <!-- ── EDIT: Add or remove sponsorship options ── -->
          <select id="rsvp-sponsorship">
            <option value="flowers">Flowers</option>
            <option value="catering">Catering</option>
            <option value="photography">Photography</option>
            <option value="venue">Venue</option>
            <option value="others">Others</option>
          </select>
        </div>

        <button class="submit-btn full" onclick="submitRSVP()">Confirm RSVP</button>
      </div>
    </div>

    <div id="rsvp-success" style="display:none;" class="section">
      <div class="success-msg">
        <!-- ── EDIT: Change success message ── -->
        <p>Thank you!</p>
        <span>Your RSVP has been received. See you on September 24!</span><br>
        <button class="ghost-btn" onclick="resetRSVP()">Submit another response</button>
      </div>
    </div>

  </div><!-- /page-rsvp -->


  <!-- ═══════════════════════════════════
       PAGE 3 — RESPONSES DASHBOARD
  ═══════════════════════════════════ -->
  <div id="page-responses" class="page">
    <div class="section">
      <div id="stats-row" class="stats-row"></div>
      <div class="filter-row">
        <button class="filter-btn active" onclick="setFilter('all', this)">All</button>
        <button class="filter-btn" onclick="setFilter('guest', this)">Guests</button>
        <button class="filter-btn" onclick="setFilter('entourage', this)">Entourage</button>
        <button class="filter-btn" onclick="setFilter('sponsor', this)">Sponsors</button>
        <button class="filter-btn" onclick="setFilter('yes', this)">Attending</button>
        <button class="filter-btn" onclick="setFilter('no', this)">Declined</button>
      </div>
      <div class="responses-wrap">
        <table class="resp-table">
          <thead>
            <tr>
              <th>Name</th><th>Type</th><th>RSVP</th><th>Message</th><th></th>
            </tr>
          </thead>
          <tbody id="resp-tbody"></tbody>
        </table>
        <div id="empty-state" class="empty-state" style="display:none;">No responses yet.</div>
      </div>
    </div>
  </div><!-- /page-responses -->

</div><!-- /.wrap -->

<!-- Scripts (order matters) -->
<script src="js/navigation.js"></script>
<script src="js/countdown.js"></script>
<script src="js/rsvp.js"></script>
<script src="js/responses.js"></script>
<script src="js/photo.js"></script>
<script src="js/invites.js"></script>
  <script src="js/app.js"></script>

  <!-- Invite modal -->
  <div id="invite-modal" class="invite-modal" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="modal-card">
      <div class="modal-title">You're invited</div>
      <div class="modal-body" id="invite-modal-body">We want to invite you as "Nickname".</div>
      <div class="modal-actions">
        <button class="btn primary" id="invite-modal-ok">Continue</button>
        <button class="btn ghost" id="invite-modal-close">Close</button>
      </div>
    </div>
  </div>

</body>
</html>